# ── Copy this to .env on your deployment platform ──────────────────────
# Set these as environment variables in Railway / Fly.io / Render dashboard

NODE_ENV=production

# Server port (Railway sets this automatically, Fly.io uses 8080)
PORT=3001

# REQUIRED: Change this to a long random string before going live
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

JWT_EXPIRY=7d

# REQUIRED: Your admin login credentials — change immediately
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_BEFORE_DEPLOYING

# REQUIRED: Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Database — use persistent volume path on Railway/Fly.io
# Railway: /app/data/library.sqlite  (after mounting a volume)
# Fly.io:  /data/library.sqlite
# Render:  /opt/render/project/src/db/library.sqlite (ephemeral! use external DB)
DB_PATH=/data/library.sqlite

# Uploaded images path (on persistent volume)
UPLOADS_DIR=/data/uploads
